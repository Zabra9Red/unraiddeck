# UnraidDeck — variabili d'ambiente (vedi README)

PORT=8787
TZ=Europe/Rome

# Solo bootstrap primo avvio: crea l'utente "admin". Rimuovere dopo il setup.
#PASSWORD=

# Server Unraid
UNRAID_HOST=192.168.1.10
# Override endpoint GraphQL (default: http://UNRAID_HOST)
#UNRAID_URL=https://192.168.1.10
# Accetta cert self-signed sul GraphQL (SSL forzato => cert myunraid.net su IP locale)
#UNRAID_TLS_INSECURE=true
# API key Unraid 7.x: unraid-api apikey --create
#UNRAID_API_KEY=

# Fallback SSH (Unraid 6.12)
#SSH_USER=root
#SSH_PASSWORD=
#SSH_KEY=/config/id_ed25519

# Endpoint Docker alternativo (default: /var/run/docker.sock)
#DOCKER_HOST=tcp://socket-proxy:2375

# Sicurezza
#DISABLE_AUTH=false
#TRUST_PROXY=true

# Aggiornamenti
#UPDATE_CHECK_INTERVAL=6h
#UPDATE_VERIFY_TIMEOUT=30s

# Notifiche webhook (POST JSON compatibile Gotify/ntfy/Discord)
#NOTIFY_WEBHOOK_URL=

# Directory dati (default /config nel container)
#CONFIG_DIR=/config

# Polling fallback SSH
#POLL_SYSTEM=5s
#POLL_ARRAY=30s
#POLL_DISKS=60s
#POLL_SHARES=300s
